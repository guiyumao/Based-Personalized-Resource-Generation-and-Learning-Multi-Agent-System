PROJECT_NAME=personalized-learning-system
ENVIRONMENT=development
DEBUG=true

POSTGRES_DB=learning_system
POSTGRES_USER=replace-with-postgres-user
POSTGRES_PASSWORD=replace-with-postgres-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=replace-with-rabbitmq-user
RABBITMQ_PASSWORD=replace-with-rabbitmq-password
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@rabbitmq:5672/

NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace-with-neo4j-password

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-minio-secret-key
MINIO_SECURE=false
MINIO_BUCKET=learning-assets

ELASTICSEARCH_URL=http://elasticsearch:9200
CHROMA_PERSIST_DIRECTORY=/data/chroma
USER_SERVICE_URL=http://user-service:8001
AGENT_SERVICE_URL=http://agent-service:8002
RESOURCE_SERVICE_URL=http://resource-service:8003
EVALUATION_SERVICE_URL=http://evaluation-service:8004
TEACHER_SERVICE_URL=http://teacher-service:8005
SYSTEM_SERVICE_URL=http://system-service:8006
CORS_ALLOW_ORIGINS=http://127.0.0.1:5175,http://localhost:5175

JWT_SECRET_KEY=replace-with-a-strong-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120
PASSWORD_SALT=
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=replace-with-a-local-admin-password
DEFAULT_ADMIN_EMAIL=admin@example.com

OPENAI_API_KEY=your-openai-compatible-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Configure either OPENAI_API_KEY or the provider-specific key below.
# DeepSeek/Qwen are OpenAI-compatible and can use their own keys directly.
QWEN_API_KEY=
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
LLM_REQUEST_TIMEOUT_SECONDS=30
RESOURCE_COURSEWARE_VARIANT_COUNT=1
RESOURCE_RAG_TOP_K=2
EXERCISE_CONTEXT_MAX_CHARS=900
