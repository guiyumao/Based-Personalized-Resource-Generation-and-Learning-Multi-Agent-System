PROJECT_NAME=personalized-learning-system
ENVIRONMENT=development
DEBUG=true

POSTGRES_DB=learning_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/learning_system

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4jpassword

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=learning-assets

ELASTICSEARCH_URL=http://elasticsearch:9200
CHROMA_PERSIST_DIRECTORY=/data/chroma
USER_SERVICE_URL=http://user-service:8001
AGENT_SERVICE_URL=http://agent-service:8002
RESOURCE_SERVICE_URL=http://resource-service:8003
EVALUATION_SERVICE_URL=http://evaluation-service:8004
TEACHER_SERVICE_URL=http://teacher-service:8005
SYSTEM_SERVICE_URL=http://system-service:8006

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120
PASSWORD_SALT=learning-system-salt

OPENAI_API_KEY=your-openai-compatible-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# If you want to use Qwen or DeepSeek through OpenAI-compatible APIs,
# keep OPENAI_API_KEY filled with the provider key and set one base URL below.
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
LLM_REQUEST_TIMEOUT_SECONDS=30
RESOURCE_COURSEWARE_VARIANT_COUNT=1
RESOURCE_RAG_TOP_K=2
EXERCISE_CONTEXT_MAX_CHARS=900
